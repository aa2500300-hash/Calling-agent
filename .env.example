# =============================================================================
# .env — copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# =============================================================================

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Get from: cloud.livekit.io → your project → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Gemini (FREE tier) ─────────────────────────────────────────────────
# Get from: aistudio.google.com → Get API Key
# Add ₹500 billing balance to activate (free tier still applies after that)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-3.1-flash-live-preview
GEMINI_VOICE=Aoede

# ── Vobiz SIP trunk ───────────────────────────────────────────────────────────
# Get from: vobiz.ai → SIP → Trunks
VOBIZ_SIP_DOMAIN=xxxxxxxx.sip.vobiz.ai
VOBIZ_SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# Number to transfer calls to when caller asks for a human
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Your Business Details ─────────────────────────────────────────────────────
BUSINESS_NAME=Your Business Name Here
BUSINESS_SERVICES=appointments, product enquiries, customer support
BUSINESS_HOURS=Monday to Saturday, 9am to 6pm
BUSINESS_LOCATION=Prayagraj, Uttar Pradesh
