# =============================================================================
# OutboundAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.
# =============================================================================

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# Get from: cloud.livekit.io → your project → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq (FREE — recommended LLM for testing) ────────────────────────────────
# Get from: console.groq.com → API Keys (completely free)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile

# ── Deepgram (FREE tier — STT + TTS) ─────────────────────────────────────────
# Get from: console.deepgram.com → API Keys ($200 free credit on signup)
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STT_MODEL=nova-2
STT_LANGUAGE=en
TTS_PROVIDER=deepgram
DEEPGRAM_TTS_MODEL=aura-asteria-en

# ── OpenAI (OPTIONAL — only if you want GPT-4o or OpenAI TTS) ────────────────
# Leave blank if using Groq + Deepgram (free stack)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini
# TTS_PROVIDER=openai
# OPENAI_TTS_VOICE=alloy

# ── Sarvam (OPTIONAL — Indian accent voices, free tier) ──────────────────────
# Get from: app.sarvam.ai → API Keys
# SARVAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TTS_PROVIDER=sarvam
# SARVAM_VOICE=anushka
# SARVAM_LANGUAGE=en-IN

# ── Vobiz SIP (for routing WhatsApp calls) ────────────────────────────────────
# Get from: vobiz.ai → SIP → Trunks
VOBIZ_SIP_DOMAIN=xxxxxxxx.sip.vobiz.ai
VOBIZ_SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxx
VOBIZ_USERNAME=your_username
VOBIZ_PASSWORD=your_password
VOBIZ_OUTBOUND_NUMBER=+91XXXXXXXXXX

# Number to transfer calls to if caller asks for a human
DEFAULT_TRANSFER_NUMBER=+91XXXXXXXXXX

# ── Business Details (shown in agent's greeting) ───────────────────────────────
BUSINESS_NAME=Your Business Name
BUSINESS_SERVICES=appointments, product enquiries, customer support
BUSINESS_HOURS=Monday to Saturday, 9am to 6pm
BUSINESS_LOCATION=Prayagraj, Uttar Pradesh
